<!DOCTYPE html>
<html lang="pt-BR">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Gerador de Login</title>

<link rel="stylesheet" href="css/style.css">

</head>

<body>

<div class="container">

<img src="img/logo.png" class="logo">

<h1>Gerador de Login</h1>

<label>Nome do Cliente</label>
<input type="text" id="nome">

<label>Cidade</label>
<select id="cidade">

<option>Monte Carlo</option>
<option>Fraiburgo</option>
<option>Caçador</option>

</select>

<button onclick="gerarLogin()">
Gerar Login
</button>

<div id="resultado">

<h3>Usuário</h3>

<p id="usuario"></p>

<h3>Senha</h3>

<p id="senha"></p>

</div>

</div>

<script src="js/script.js"></script>

</body>

</html>